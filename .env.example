# Provider: "claude" (default — uses claude CLI) or "gemini" (Google AI Studio)
# Frontend can override this per-turn via the model picker.
LLM_PROVIDER=claude

# Required only if using gemini. Get a key from https://aistudio.google.com
GEMINI_API_KEY=

# Optional model overrides. Defaults: claude=sonnet, gemini=gemini-3-flash-preview
# CLAUDE_MODEL=sonnet
# GEMINI_MODEL=gemini-3-flash-preview

# Enable Gemini's google_search grounding for real-time web data in UI nodes.
# Tradeoff: grounding is incompatible with responseSchema, so the model is
# instructed to emit JSON via prompt instead of enforced structured output.
# Slightly higher risk of malformed output, much higher data freshness.
# GEMINI_GROUNDING=true
